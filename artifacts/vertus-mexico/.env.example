# Frontend (@workspace/vertus-mexico) — copy to `.env` and adjust.
# Vite reads these at config load, so BUILD and DEV both fail if the two
# required vars are unset.

# ── Required ──────────────────────────────────────────────────────────────
PORT=5173          # port the dev/preview server binds to
BASE_PATH=/        # base public path (Vite `base`); "/" for root deploys

# ── Optional ──────────────────────────────────────────────────────────────
# VITE_GTM_ID=GTM-XXXXXXX          # Google Tag Manager container id (analytics)
# VITE_SITE_URL=https://vertus.mx  # canonical URL; used to generate sitemap.xml
